generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LogisticMessage {
  id                Int       @id @default(autoincrement())
  tgMessageId       Int       // Telegram xabar ID
  channelName       String
  text              String
  date              DateTime?
  views             Int?

  aiStatus          String     // "LOAD_POST" | "REGULAR_MESSAGE"
  structured        Json?
  normalized        Json?

  countryFrom       String?
  countryTo         String?
  regionFrom        String?
  regionTo          String?

  title             String?
  weight            Float?
  cargoUnit         String?
  vehicleType       String?
  paymentType       String?
  paymentAmount     Float?
  advancePayment    Float?
  paymentCurrency   String?
  pickupDate        DateTime?
  phoneNumber       String?

  sentToTelegramAt  DateTime?
  isComplete        Boolean @default(false)

  isActual          Boolean    @default(true) // xabar yangimi yoki yo‘qmi
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model TelegramGroup {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          Int       @id @default(autoincrement())
  fullName    String?
  username    String?   @unique
  phone       String?   @unique
  password    String?
  role        UserRole  @default(DISPATCHER)
  isActive    Boolean   @default(true)
  paymentKey  String?
  paymentDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  DISPATCHER
}

enum VerificationPurpose {
  REGISTER
  RESET_PASSWORD
}

model VerificationCode {
  id            Int                 @id @default(autoincrement())
  phone         String
  codeHash      String
  purpose       VerificationPurpose
  attemptsLeft  Int                 @default(3)
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime            @default(now())

  @@index([phone, purpose])
}
