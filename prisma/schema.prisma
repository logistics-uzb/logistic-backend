generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostSource {
  SCRAPING
  DISPATCHER
}

// Dispatcher yuborgan xabar Telegramga jo'natish holati.
// PENDING  → hali navbatga qo'shilmagan (odatda create bo'lganda)
// QUEUED   → Python worker'ga o'tkazildi, navbatda kutmoqda
// SENDING  → Python hozir jo'natmoqda
// SENT     → Barcha guruhlarga muvaffaqiyatli
// PARTIAL  → Ba'zi guruhlar muvaffaqiyatsiz (bloklangan/xato)
// FAILED   → Umuman jo'natilmadi (masalan Python xatosi)
// CANCELLED→ Dispatcher bekor qildi navbatda kutayotganda
enum SendStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  PARTIAL
  FAILED
  CANCELLED
}

model LogisticMessage {
  id                Int       @id @default(autoincrement())
  tgMessageId       Int       // Telegram xabar ID
  channelName       String
  text              String
  date              DateTime?
  views             Int?

  // Bitta uzun Telegram habardan bir nechta yuk ajratib olinganda,
  // har bir yuk alohida row sifatida saqlanadi. blockIndex shu bo'lakning
  // habar ichidagi tartib raqami (0 = birinchi yuk, 1 = ikkinchi, ...).
  // Qisqa habarlarda (oddiy bitta yuk) blockIndex = 0.
  blockIndex        Int        @default(0)

  aiStatus          String     // "LOAD_POST" | "REGULAR_MESSAGE"
  structured        Json?
  normalized        Json?

  countryFrom       String?
  countryTo         String?
  regionFrom        String?
  regionTo          String?

  title             String?
  weight            Float?
  cargoUnit         String?
  vehicleType       String?
  paymentType       String?
  paymentAmount     Float?
  advancePayment    Float?
  paymentCurrency   String?
  pickupDate        DateTime?
  phoneNumber       String?

  sentToTelegramAt  DateTime?
  isComplete        Boolean @default(false)

  // Ma'lum viloyatlar orasidagi yo'nalishlar uchun taxminiy masofa/vaqt (Haversine + 1.30 koef).
  // O'zb, Qozog'iston, Qirg'iziston, Tojikiston, Belarus, Turkiya viloyatlari qo'llab-quvvatlanadi.
  // Faqat LOAD_POST saqlanayotganda va ikkala region region-coords ro'yxatida bo'lsa to'ladi.
  distanceDirectKm     Float?
  distanceKm           Float?
  distanceTimeMinutes  Float?
  // Bir km uchun narx (paymentAmount / distanceKm). Uch shart bajarilgandagina:
  //   paymentAmount != null && distanceKm != null && paymentCurrency != null.
  // Valyuta `paymentCurrency` ustunidan olinadi.
  pricePerKm           Float?

  // Front tomonidan yig'iladigan statistika:
  //   viewCount — post batafsil ochilgan (yoki karta ko'rilgan) marta
  //   callCount — telefon raqami bosilgan (aloqa urunilgan) marta
  // Har biri POST /v1/post/view-increment orqali +1 bo'lib boradi.
  // NB: `views` maydoni bu emas — u Telegram post ko'rishlari (scraper qaytaradi).
  viewCount            Int      @default(0)
  callCount            Int      @default(0)

  source            PostSource @default(SCRAPING)
  createdById       Int?
  createdBy         User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)

  // MTProto jo'natish jarayoni holati. Faqat dispatcher yuborgan
  // xabarlar (source = DISPATCHER) uchun mazmunga ega. SCRAPING
  // xabarlari uchun PENDING'da qoladi (default).
  sendStatus        SendStatus @default(PENDING)
  queuedAt          DateTime?  // Python'ga jo'natilgan vaqt
  sendStartedAt     DateTime?  // Worker ish boshlagan vaqt
  sendFinishedAt    DateTime?  // Barcha guruhlar tugagan vaqt
  // sendResults shakli:
  //   [{ group: "@somegroup", ok: true, sentAt: "..." },
  //    { group: "@other", ok: false, error: "peer_flood", errorRaw: "..." }]
  sendResults       Json?

  isActual          Boolean    @default(true) // xabar yangimi yoki yo‘qmi
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // NOTE: No DB-level unique constraint on (tgMessageId, channelName,
  // blockIndex). Application-level dedup in PostsService.create
  // (findFirst by tgMessageId+channelName) is the source of truth.
  // Reason: dispatcher posts all share the sentinel pair
  // (tgMessageId=0, channelName='DISPATCHER') by design, which would
  // collide with any unique constraint covering those columns.
  @@index([source])
  @@index([createdById])
  @@index([tgMessageId, channelName])
  @@index([sendStatus])
}

model TelegramGroup {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Guruhga jo'natishda xatolik uchragan holatda 24 soatga blocklanadi.
// Cron unblockAt < now() bo'lganlarni tozalab turadi.
// Permanent bloklar (masalan kicked) uchun unblockAt uzoq kelajakka qo'yiladi.
enum BlockReason {
  PEER_FLOOD          // PeerFloodError — 24h avtomatik
  FLOOD_WAIT          // FloodWaitError — err.seconds
  SLOW_MODE           // SlowModeWaitError — err.seconds
  WRITE_FORBIDDEN     // ChatWriteForbiddenError — admin qayta kiritishi kerak
  BANNED              // UserBannedInChannelError — permanent
  INVALID_USERNAME    // UsernameInvalidError / NotOccupiedError — guruh yo'q
  UNKNOWN             // boshqa xatoliklar
}

model BlockedGroup {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  reason     BlockReason
  blockedAt  DateTime    @default(now())
  unblockAt  DateTime
  lastError  String?     // Original xato matni (debug uchun)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([unblockAt])
}

model User {
  id          Int       @id @default(autoincrement())
  fullName    String?
  username    String?   @unique
  phone       String?   @unique
  password    String?
  role        UserRole  @default(DISPATCHER)
  isActive    Boolean   @default(true)
  paymentKey  String?
  paymentDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts       LogisticMessage[]
}

enum UserRole {
  ADMIN
  DISPATCHER
}

enum VerificationPurpose {
  REGISTER
  RESET_PASSWORD
}

model VerificationCode {
  id            Int                 @id @default(autoincrement())
  phone         String
  codeHash      String
  purpose       VerificationPurpose
  attemptsLeft  Int                 @default(3)
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime            @default(now())

  @@index([phone, purpose])
}
